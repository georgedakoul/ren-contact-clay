{
  "defaults": {
    "lookback_days": 90,
    "output_dir": "AI Sales Agent System/output/sentiment-analyser",
    "engine": {
      "classification": "mcp",
      "theme_model": "claude-sonnet-4-5"
    },
    "filters": {
      "is_brand_related": true
    },
    "cost_guard": {
      "max_credits_per_run": 5000,
      "max_credits_per_post": 1000,
      "min_quota_to_start": 50,
      "preview_before_execute": true,
      "on_budget_exceeded": "abort_with_error"
    },
    "polling": {
      "interval_seconds": 15,
      "timeout_per_analysis_seconds": 300,
      "retry_failed_once": true
    },
    "theme_extraction": {
      "model": "claude-sonnet-4-5",
      "max_comments_per_prompt": 200,
      "use_prompt_caching": true,
      "max_themes": 8,
      "max_samples_per_theme": 3,
      "analyze_captions": true,
      "pricing": {
        "input_per_token": 3e-06,
        "output_per_token": 1.5e-05,
        "cache_write_per_token": 3.75e-06,
        "cache_read_per_token": 3e-07
      }
    },
    "scoring": {
      "engagement_weighted": true
    },
    "brand_label_bands": {
      "negative_max": 5.0,
      "neutral_max": 6.5
    },
    "trend": {
      "method": "half_split",
      "min_delta_for_change": 0.5,
      "min_comments_for_trend": 20
    },
    "sentiment_cache": {
      "source": "mcp"
    },
    "input": {
      "require_perf_analyser_output": true
    },
    "feature_flags": {
      "save_to_server": false,
      "enrich_with_profile_sentiment": true
    }
  },
  "overrides": {}
}
